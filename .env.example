# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# IBKR Credentials (used by IB Gateway Docker container)
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# Google Sheet with stocks_alert rules (managed from the dashboard Alerts tab)
# Same values as in stocks_alert/.env — copy google_credentials.json here too
GOOGLE_CREDENTIALS_FILE=/app/google_credentials.json
SPREADSHEET_ID=your_google_sheet_id
SHEET_RANGE=Sheet1!A2:E100
